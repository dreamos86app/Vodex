    "\u0000 \u0000G\u0000E\u0000T\u0000 \u0000/\u0000 \u00002\u00000\u00000\u0000 \u0000i\u0000n\u0000 \u00001\u00007\u00003\u0000m\u0000s\u0000 \u0000(\u0000n\u0000e\u0000x\u0000t\u0000.\u0000j\u0000s\u0000:\u0000 \u00004\u0000m\u0000s\u0000,\u0000 \u0000p\u0000r\u0000o\u0000x\u0000y\u0000.\u0000t\u0000s\u0000:\u0000 \u00007\u0000m\u0000s\u0000,\u0000 \u0000a\u0000p\u0000p\u0000l\u0000i\u0000c\u0000a\u0000t\u0000i\u0000o\u0000n\u0000-\u0000c\u0000o\u0000d\u0000e\u0000:\u0000 \u00001\u00006\u00002\u0000m\u0000s\u0000)\u0000\r\u0000",
    "\u0000 \u0000G\u0000E\u0000T\u0000 \u0000/\u0000a\u0000p\u0000i\u0000/\u0000c\u0000r\u0000e\u0000d\u0000i\u0000t\u0000s\u0000 \u00002\u00000\u00000\u0000 \u0000i\u0000n\u0000 \u00001\u00001\u00004\u00001\u0000m\u0000s\u0000 \u0000(\u0000n\u0000e\u0000x\u0000t\u0000.\u0000j\u0000s\u0000:\u0000 \u00003\u0000m\u0000s\u0000,\u0000 \u0000p\u0000r\u0000o\u0000x\u0000y\u0000.\u0000t\u0000s\u0000:\u0000 \u00004\u00005\u00009\u0000m\u0000s\u0000,\u0000 \u0000a\u0000p\u0000p\u0000l\u0000i\u0000c\u0000a\u0000t\u0000i\u0000o\u0000n\u0000-\u0000c\u0000o\u0000d\u0000e\u0000:\u0000 \u00006\u00007\u00009\u0000m\u0000s\u0000)\u0000\r\u0000",
    "\u0000 \u0000G\u0000E\u0000T\u0000 \u0000/\u0000a\u0000p\u0000i\u0000/\u0000d\u0000e\u0000v\u0000/\u0000a\u0000u\u0000t\u0000h\u0000-\u0000s\u0000e\u0000s\u0000s\u0000i\u0000o\u0000n\u0000-\u0000c\u0000h\u0000e\u0000c\u0000k\u0000 \u00002\u00000\u00000\u0000 \u0000i\u0000n\u0000 \u00007\u00002\u00002\u0000m\u0000s\u0000 \u0000(\u0000n\u0000e\u0000x\u0000t\u0000.\u0000j\u0000s\u0000:\u0000 \u00003\u0000m\u0000s\u0000,\u0000 \u0000p\u0000r\u0000o\u0000x\u0000y\u0000.\u0000t\u0000s\u0000:\u0000 \u00004\u00006\u00002\u0000m\u0000s\u0000,\u0000 \u0000a\u0000p\u0000p\u0000l\u0000i\u0000c\u0000a\u0000t\u0000i\u0000o\u0000n\u0000-\u0000c\u0000o\u0000d\u0000e\u0000:\u0000 \u00002\u00005\u00007\u0000m\u0000s\u0000)\u0000\r\u0000",
    "\u0000 \u0000G\u0000E\u0000T\u0000 \u0000/\u0000a\u0000p\u0000i\u0000/\u0000c\u0000r\u0000e\u0000d\u0000i\u0000t\u0000s\u0000 \u00002\u00000\u00000\u0000 \u0000i\u0000n\u0000 \u00001\u00001\u00005\u00000\u0000m\u0000s\u0000 \u0000(\u0000n\u0000e\u0000x\u0000t\u0000.\u0000j\u0000s\u0000:\u0000 \u00003\u0000m\u0000s\u0000,\u0000 \u0000p\u0000r\u0000o\u0000x\u0000y\u0000.\u0000t\u0000s\u0000:\u0000 \u00004\u00006\u00004\u0000m\u0000s\u0000,\u0000 \u0000a\u0000p\u0000p\u0000l\u0000i\u0000c\u0000a\u0000t\u0000i\u0000o\u0000n\u0000-\u0000c\u0000o\u0000d\u0000e\u0000:\u0000 \u00006\u00008\u00003\u0000m\u0000s\u0000)\u0000\r\u0000",
    "\u0000 \u0000G\u0000E\u0000T\u0000 \u0000/\u0000c\u0000r\u0000e\u0000a\u0000t\u0000e\u0000?\u0000m\u0000o\u0000d\u0000e\u0000=\u0000b\u0000u\u0000i\u0000l\u0000d\u0000&\u0000s\u0000t\u0000r\u0000a\u0000t\u0000e\u0000g\u0000y\u0000=\u0000b\u0000u\u0000i\u0000l\u0000d\u0000_\u0000n\u0000o\u0000w\u0000 \u00002\u00000\u00000\u0000 \u0000i\u0000n\u0000 \u00001\u00003\u00004\u00001\u0000m\u0000s\u0000 \u0000(\u0000n\u0000e\u0000x\u0000t\u0000.\u0000j\u0000s\u0000:\u0000 \u00004\u00008\u0000m\u0000s\u0000,\u0000 \u0000p\u0000r\u0000o\u0000x\u0000y\u0000.\u0000t\u0000s\u0000:\u0000 \u00007\u00005\u00005\u0000m\u0000s\u0000,\u0000 \u0000a\u0000p\u0000p\u0000l\u0000i\u0000c\u0000a\u0000t\u0000i\u0000o\u0000n\u0000-\u0000c\u0000o\u0000d\u0000e\u0000:\u0000 \u00005\u00003\u00008\u0000m\u0000s\u0000)\u0000\r\u0000",
    "\u0000 \u0000G\u0000E\u0000T\u0000 \u0000/\u0000a\u0000p\u0000i\u0000/\u0000a\u0000i\u0000/\u0000p\u0000r\u0000o\u0000v\u0000i\u0000d\u0000e\u0000r\u0000-\u0000s\u0000t\u0000a\u0000t\u0000u\u0000s\u0000 \u00002\u00000\u00000\u0000 \u0000i\u0000n\u0000 \u00002\u00005\u00006\u0000m\u0000s\u0000 \u0000(\u0000n\u0000e\u0000x\u0000t\u0000.\u0000j\u0000s\u0000:\u0000 \u00008\u0000m\u0000s\u0000,\u0000 \u0000p\u0000r\u0000o\u0000x\u0000y\u0000.\u0000t\u0000s\u0000:\u0000 \u00002\u00003\u00008\u0000m\u0000s\u0000,\u0000 \u0000a\u0000p\u0000p\u0000l\u0000i\u0000c\u0000a\u0000t\u0000i\u0000o\u0000n\u0000-\u0000c\u0000o\u0000d\u0000e\u0000:\u0000 \u00001\u00000\u0000m\u0000s\u0000)\u0000\r\u0000",
    "\u0000 \u0000G\u0000E\u0000T\u0000 \u0000/\u0000c\u0000r\u0000e\u0000a\u0000t\u0000e\u0000?\u0000m\u0000o\u0000d\u0000e\u0000=\u0000b\u0000u\u0000i\u0000l\u0000d\u0000&\u0000s\u0000t\u0000r\u0000a\u0000t\u0000e\u0000g\u0000y\u0000=\u0000b\u0000u\u0000i\u0000l\u0000d\u0000_\u0000n\u0000o\u0000w\u0000 \u00002\u00000\u00000\u0000 \u0000i\u0000n\u0000 \u00003\u00003\u00003\u0000m\u0000s\u0000 \u0000(\u0000n\u0000e\u0000x\u0000t\u0000.\u0000j\u0000s\u0000:\u0000 \u00004\u0000m\u0000s\u0000,\u0000 \u0000p\u0000r\u0000o\u0000x\u0000y\u0000.\u0000t\u0000s\u0000:\u0000 \u00002\u00006\u00000\u0000m\u0000s\u0000,\u0000 \u0000a\u0000p\u0000p\u0000l\u0000i\u0000c\u0000a\u0000t\u0000i\u0000o\u0000n\u0000-\u0000c\u0000o\u0000d\u0000e\u0000:\u0000 \u00006\u00009\u0000m\u0000s\u0000)\u0000\r\u0000",
    "\u0000 \u0000G\u0000E\u0000T\u0000 \u0000/\u0000c\u0000r\u0000e\u0000a\u0000t\u0000e\u0000?\u0000m\u0000o\u0000d\u0000e\u0000=\u0000b\u0000u\u0000i\u0000l\u0000d\u0000&\u0000s\u0000t\u0000r\u0000a\u0000t\u0000e\u0000g\u0000y\u0000=\u0000b\u0000u\u0000i\u0000l\u0000d\u0000_\u0000n\u0000o\u0000w\u0000 \u00002\u00000\u00000\u0000 \u0000i\u0000n\u0000 \u00005\u00005\u00009\u0000m\u0000s\u0000 \u0000(\u0000n\u0000e\u0000x\u0000t\u0000.\u0000j\u0000s\u0000:\u0000 \u00007\u0000m\u0000s\u0000,\u0000 \u0000p\u0000r\u0000o\u0000x\u0000y\u0000.\u0000t\u0000s\u0000:\u0000 \u00003\u00002\u00001\u0000m\u0000s\u0000,\u0000 \u0000a\u0000p\u0000p\u0000l\u0000i\u0000c\u0000a\u0000t\u0000i\u0000o\u0000n\u0000-\u0000c\u0000o\u0000d\u0000e\u0000:\u0000 \u00002\u00003\u00000\u0000m\u0000s\u0000)\u0000\r\u0000",
    "\u0000 \u0000G\u0000E\u0000T\u0000 \u0000/\u0000c\u0000r\u0000e\u0000a\u0000t\u0000e\u0000?\u0000m\u0000o\u0000d\u0000e\u0000=\u0000b\u0000u\u0000i\u0000l\u0000d\u0000&\u0000s\u0000t\u0000r\u0000a\u0000t\u0000e\u0000g\u0000y\u0000=\u0000b\u0000u\u0000i\u0000l\u0000d\u0000_\u0000n\u0000o\u0000w\u0000 \u00002\u00000\u00000\u0000 \u0000i\u0000n\u0000 \u00003\u00006\u00003\u0000m\u0000s\u0000 \u0000(\u0000n\u0000e\u0000x\u0000t\u0000.\u0000j\u0000s\u0000:\u0000 \u00006\u0000m\u0000s\u0000,\u0000 \u0000p\u0000r\u0000o\u0000x\u0000y\u0000.\u0000t\u0000s\u0000:\u0000 \u00002\u00006\u00008\u0000m\u0000s\u0000,\u0000 \u0000a\u0000p\u0000p\u0000l\u0000i\u0000c\u0000a\u0000t\u0000i\u0000o\u0000n\u0000-\u0000c\u0000o\u0000d\u0000e\u0000:\u0000 \u00008\u00009\u0000m\u0000s\u0000)\u0000\r\u0000",
    "\u0000 \u0000G\u0000E\u0000T\u0000 \u0000/\u0000c\u0000r\u0000e\u0000a\u0000t\u0000e\u0000?\u0000m\u0000o\u0000d\u0000e\u0000=\u0000b\u0000u\u0000i\u0000l\u0000d\u0000&\u0000s\u0000t\u0000r\u0000a\u0000t\u0000e\u0000g\u0000y\u0000=\u0000b\u0000u\u0000i\u0000l\u0000d\u0000_\u0000n\u0000o\u0000w\u0000 \u00002\u00000\u00000\u0000 \u0000i\u0000n\u0000 \u00001\u00001\u00002\u00001\u0000m\u0000s\u0000 \u0000(\u0000n\u0000e\u0000x\u0000t\u0000.\u0000j\u0000s\u0000:\u0000 \u00005\u0000m\u0000s\u0000,\u0000 \u0000p\u0000r\u0000o\u0000x\u0000y\u0000.\u0000t\u0000s\u0000:\u0000 \u00007\u00005\u00006\u0000m\u0000s\u0000,\u0000 \u0000a\u0000p\u0000p\u0000l\u0000i\u0000c\u0000a\u0000t\u0000i\u0000o\u0000n\u0000-\u0000c\u0000o\u0000d\u0000e\u0000:\u0000 \u00003\u00005\u00009\u0000m\u0000s\u0000)\u0000\r\u0000",
    "\u0000 \u0000G\u0000E\u0000T\u0000 \u0000/\u0000a\u0000p\u0000i\u0000/\u0000a\u0000i\u0000/\u0000p\u0000r\u0000o\u0000v\u0000i\u0000d\u0000e\u0000r\u0000-\u0000s\u0000t\u0000a\u0000t\u0000u\u0000s\u0000 \u00002\u00000\u00000\u0000 \u0000i\u0000n\u0000 \u00002\u00004\u00006\u0000m\u0000s\u0000 \u0000(\u0000n\u0000e\u0000x\u0000t\u0000.\u0000j\u0000s\u0000:\u0000 \u00003\u0000m\u0000s\u0000,\u0000 \u0000p\u0000r\u0000o\u0000x\u0000y\u0000.\u0000t\u0000s\u0000:\u0000 \u00002\u00003\u00004\u0000m\u0000s\u0000,\u0000 \u0000a\u0000p\u0000p\u0000l\u0000i\u0000c\u0000a\u0000t\u0000i\u0000o\u0000n\u0000-\u0000c\u0000o\u0000d\u0000e\u0000:\u0000 \u00009\u0000m\u0000s\u0000)\u0000\r\u0000",
    "\u0000 \u0000G\u0000E\u0000T\u0000 \u0000/\u0000c\u0000r\u0000e\u0000a\u0000t\u0000e\u0000?\u0000m\u0000o\u0000d\u0000e\u0000=\u0000b\u0000u\u0000i\u0000l\u0000d\u0000&\u0000s\u0000t\u0000r\u0000a\u0000t\u0000e\u0000g\u0000y\u0000=\u0000b\u0000u\u0000i\u0000l\u0000d\u0000_\u0000n\u0000o\u0000w\u0000 \u00002\u00000\u00000\u0000 \u0000i\u0000n\u0000 \u00003\u00004\u00005\u0000m\u0000s\u0000 \u0000(\u0000n\u0000e\u0000x\u0000t\u0000.\u0000j\u0000s\u0000:\u0000 \u00004\u0000m\u0000s\u0000,\u0000 \u0000p\u0000r\u0000o\u0000x\u0000y\u0000.\u0000t\u0000s\u0000:\u0000 \u00002\u00007\u00001\u0000m\u0000s\u0000,\u0000 \u0000a\u0000p\u0000p\u0000l\u0000i\u0000c\u0000a\u0000t\u0000i\u0000o\u0000n\u0000-\u0000c\u0000o\u0000d\u0000e\u0000:\u0000 \u00006\u00009\u0000m\u0000s\u0000)\u0000\r\u0000",
