# ─── Supabase ─────────────────────────────────────────────────────────────────
# From: https://supabase.com/dashboard/project/<project-id>/settings/api
NEXT_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co
# Dashboard calls this "anon key" or "publishable key" — both are the same JWT/sb_publishable value
NEXT_PUBLIC_SUPABASE_ANON_KEY=<your-anon-or-publishable-key>

# ─── Stripe ────────────────────────────────────────────────────────────────────
# From: https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
# From: https://dashboard.stripe.com/apikeys (publishable)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...

# ─── AI providers ─────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...
GOOGLE_GENERATIVE_AI_API_KEY=AIza...

# ─── App ──────────────────────────────────────────────────────────────────────
# Local dev MUST use localhost — do not copy production URL here or navigation/OAuth will leave localhost.
# Production (Vercel): set NEXT_PUBLIC_APP_URL to your deployed origin.
NEXT_PUBLIC_APP_URL=http://localhost:3000
# Optional marketing/canonical URL for production OG + referral links only (not used for in-app navigation in dev).
# NEXT_PUBLIC_SITE_URL=https://dreamos86.com
NEXT_PUBLIC_SUPPORT_EMAIL=support@vodex.dev

# ─── Vercel deploy (Deployment Center — server only, never NEXT_PUBLIC_) ─────
# Create at https://vercel.com/account/settings/tokens
VERCEL_ACCESS_TOKEN=
# Optional: VERCEL_TEAM_ID=  VERCEL_PROJECT_ID=

# ─── Resend (transactional email) ─────────────────────────────────────────────
RESEND_API_KEY=re_...

# ─── Integrations (P2 — server only) ───────────────────────────────────────────
# 64-char hex — encrypts project secrets + linked provider tokens
APP_SECRET_ENCRYPTION_KEY=
# or: DREAMOS_SECRETS_MASTER_KEY=

# GitHub OAuth (account + per-app one-click)
# https://github.com/settings/developers — callback: {NEXT_PUBLIC_APP_URL}/api/integrations/github/callback
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_OAUTH_STATE_SECRET=

# Supabase platform DB (integration routes)
SUPABASE_SERVICE_ROLE_KEY=
