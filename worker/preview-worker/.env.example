SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
PREVIEW_WORKER_ID=preview-worker-local-1
PREVIEW_WORKSPACE_DIR=/tmp/vodex-preview-workspaces
PREVIEW_ARTIFACT_BUCKET=preview-artifacts
PREVIEW_SOURCE_BUCKET=preview-sources
PREVIEW_JOB_CONCURRENCY=1
PREVIEW_INSTALL_TIMEOUT_MS=180000
PREVIEW_BUILD_TIMEOUT_MS=180000
PREVIEW_MAX_FILES=20000
PREVIEW_MAX_SOURCE_MB=250
PREVIEW_POLL_INTERVAL_MS=5000
PREVIEW_ALLOW_NPM_SCRIPTS=0
# V8 heap for vite build (MB). Container needs heap + ~512MB headroom.
PREVIEW_NODE_MAX_OLD_SPACE_MB=4096
